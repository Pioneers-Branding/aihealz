// ══════════════════════════════════════════════════════════════════════════════
// AUDIT LOG - Track all admin and important user actions
// ══════════════════════════════════════════════════════════════════════════════

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorType  String   @map("actor_type") @db.VarChar(20) // 'admin', 'provider', 'system', 'user'
  actorId    String?  @map("actor_id") @db.VarChar(100)
  actorEmail String?  @map("actor_email") @db.VarChar(255)
  action     String   @db.VarChar(100) // 'create', 'update', 'delete', 'login', 'export', etc.
  resource   String   @db.VarChar(100) // 'doctor', 'condition', 'content', 'lead', etc.
  resourceId String?  @map("resource_id") @db.VarChar(100)
  changes    Json? // { field: { old: value, new: value } }
  metadata   Json? // Additional context (IP, user agent, etc.)
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
  status     String   @default("success") @db.VarChar(20) // 'success', 'failure', 'pending'
  errorMsg   String?  @map("error_msg")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([actorType, actorId])
  @@index([action])
  @@index([resource, resourceId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

// ══════════════════════════════════════════════════════════════════════════════
// FEATURE FLAGS - Control feature rollout and A/B testing
// ══════════════════════════════════════════════════════════════════════════════

model FeatureFlag {
  id          Int       @id @default(autoincrement())
  key         String    @unique @db.VarChar(100)
  name        String    @db.VarChar(200)
  description String?
  isEnabled   Boolean   @default(false) @map("is_enabled")
  rolloutPct  Int       @default(100) @map("rollout_pct") // 0-100 percentage for gradual rollout
  targetRules Json?     @map("target_rules") // { countries: [], tiers: [], userIds: [] }
  variants    Json? // For A/B testing: [{ name: 'control', weight: 50 }, { name: 'variant', weight: 50 }]
  category    String    @default("general") @db.VarChar(50)
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz(6)
  createdBy   String?   @map("created_by") @db.VarChar(100)
  updatedBy   String?   @map("updated_by") @db.VarChar(100)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([isEnabled])
  @@index([category])
  @@map("feature_flags")
}

// ══════════════════════════════════════════════════════════════════════════════
// MEDICAL SPECIALTY - Standardized specialty definitions
// ══════════════════════════════════════════════════════════════════════════════

model MedicalSpecialty {
  id               Int      @id @default(autoincrement())
  slug             String   @unique @db.VarChar(100)
  name             String   @db.VarChar(200)
  shortName        String?  @map("short_name") @db.VarChar(50)
  description      String?
  icon             String?  @db.VarChar(50) // Icon name or emoji
  category         String   @db.VarChar(50) // 'surgical', 'medical', 'diagnostic', 'dental', etc.
  parentId         Int?     @map("parent_id")
  bodySystem       String?  @map("body_system") @db.VarChar(100)
  commonConditions String[] @default([]) @map("common_conditions") // condition slugs
  relatedTests     String[] @default([]) @map("related_tests") // test slugs
  consultTypes     String[] @default([]) @map("consult_types") // 'in-person', 'video', 'chat'
  avgConsultFeeInr Decimal? @map("avg_consult_fee_inr") @db.Decimal(10, 2)
  avgConsultFeeUsd Decimal? @map("avg_consult_fee_usd") @db.Decimal(10, 2)
  searchVolume     Int?     @map("search_volume")
  metaTitle        String?  @map("meta_title") @db.VarChar(160)
  metaDescription  String?  @map("meta_description") @db.VarChar(300)
  isActive         Boolean  @default(true) @map("is_active")
  displayOrder     Int      @default(0) @map("display_order")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  parent   MedicalSpecialty?  @relation("SpecialtyHierarchy", fields: [parentId], references: [id])
  children MedicalSpecialty[] @relation("SpecialtyHierarchy")

  @@index([category])
  @@index([parentId])
  @@index([isActive, displayOrder])
  @@map("medical_specialties")
}

// ══════════════════════════════════════════════════════════════════════════════
// API RATE LIMIT - Track API usage for rate limiting
// ══════════════════════════════════════════════════════════════════════════════

model ApiRateLimit {
  id           Int      @id @default(autoincrement())
  identifier   String   @db.VarChar(255) // IP, API key, or user ID
  endpoint     String   @db.VarChar(255)
  windowStart  DateTime @map("window_start") @db.Timestamptz(6)
  requestCount Int      @default(1) @map("request_count")

  @@unique([identifier, endpoint, windowStart])
  @@index([windowStart])
  @@map("api_rate_limits")
}

// ══════════════════════════════════════════════════════════════════════════════
// EMAIL QUEUE - For async email sending
// ══════════════════════════════════════════════════════════════════════════════

model EmailQueue {
  id           String    @id @default(uuid()) @db.Uuid
  templateName String    @map("template_name") @db.VarChar(100)
  toEmail      String    @map("to_email") @db.VarChar(255)
  toName       String?   @map("to_name") @db.VarChar(200)
  subject      String    @db.VarChar(500)
  variables    Json      @default("{}")
  priority     Int       @default(5) // 1-10, lower = higher priority
  status       String    @default("pending") @db.VarChar(20) // 'pending', 'sent', 'failed', 'cancelled'
  attempts     Int       @default(0)
  lastAttempt  DateTime? @map("last_attempt") @db.Timestamptz(6)
  sentAt       DateTime? @map("sent_at") @db.Timestamptz(6)
  errorMsg     String?   @map("error_msg")
  sendgridId   String?   @map("sendgrid_id") @db.VarChar(100)
  scheduledFor DateTime? @map("scheduled_for") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([status, priority, createdAt])
  @@index([toEmail])
  @@index([templateName, status])
  @@map("email_queue")
}
