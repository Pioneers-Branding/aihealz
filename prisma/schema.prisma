generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Language {
  code             String             @id @db.VarChar(5)
  name             String             @db.VarChar(100)
  nativeName       String?            @map("native_name") @db.VarChar(100)
  isActive         Boolean            @default(true) @map("is_active")
  localizedContent LocalizedContent[]
  sitemapEntries   SitemapEntry[]
  translations     TranslationQueue[] @relation("TranslationLang")
  uiTranslations   UiTranslation[]

  @@map("languages")
}

model MedicalCondition {
  id                 Int                    @id @default(autoincrement())
  slug               String                 @unique @db.VarChar(255)
  scientificName     String                 @map("scientific_name") @db.VarChar(500)
  commonName         String                 @map("common_name") @db.VarChar(500)
  description        String?
  symptoms           Json                   @default("[]")
  treatments         Json                   @default("[]")
  faqs               Json                   @default("[]")
  specialistType     String                 @map("specialist_type") @db.VarChar(100)
  severityLevel      String?                @map("severity_level") @db.VarChar(20)
  icdCode            String?                @map("icd_code") @db.VarChar(20)
  bodySystem         String?                @map("body_system") @db.VarChar(100)
  schemaMarkup       Json?                  @map("schema_markup")
  isActive           Boolean                @default(true) @map("is_active")
  createdAt          DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  conditionReviewers ConditionReviewer[]
  doctorSpecialties  DoctorSpecialty[]
  icd10Mappings      Icd10SpecialtyMap[]
  localizedContent   LocalizedContent[]
  pinnedConditions   PinnedCondition[]
  seasonalTriggers   SeasonalTrigger[]
  sitemapEntries     SitemapEntry[]
  pageContent        ConditionPageContent[]

  @@index([isActive, commonName])
  @@index([specialistType])
  @@index([bodySystem])
  @@map("medical_conditions")
}

model Geography {
  id                      Int                      @id @default(autoincrement())
  name                    String                   @db.VarChar(255)
  slug                    String                   @db.VarChar(255)
  level                   GeoLevel
  parentId                Int?                     @map("parent_id")
  latitude                Decimal?                 @db.Decimal(10, 7)
  longitude               Decimal?                 @db.Decimal(10, 7)
  supportedLanguages      String[]                 @map("supported_languages") @db.VarChar(5)
  population              BigInt?
  timezone                String?                  @db.VarChar(50)
  isoCode                 String?                  @map("iso_code") @db.VarChar(5)
  localeConfig            Json                     @default("{}") @map("locale_config")
  isActive                Boolean                  @default(true) @map("is_active")
  createdAt               DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  advertisers             Advertiser[]
  analysisResults         AnalysisResult[]         @relation("AnalysisGeo")
  conditionReviewers      ConditionReviewer[]
  badgeDoctors            DoctorProvider[]         @relation("BadgeCity")
  doctors                 DoctorProvider[]
  encounters              Encounter[]              @relation("EncounterGeo")
  enquiryLogs             EnquiryLog[]             @relation("EnquiryGeo")
  footerTemplates         FooterTemplate[]         @relation("FooterGeo")
  geoAnalytics            GeoAnalytics[]
  parent                  Geography?               @relation("GeoHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children                Geography[]              @relation("GeoHierarchy")
  keywordGaps             KeywordGap[]             @relation("KeywordGeo")
  leadLogs                LeadLog[]                @relation("LeadGeo")
  localizedContent        LocalizedContent[]
  pinnedConditions        PinnedCondition[]
  providerAnalytics       ProviderAnalytics[]      @relation("AnalyticsGeo")
  seasonalTriggers        SeasonalTrigger[]
  sitemapEntries          SitemapEntry[]
  smartMatchNotifications SmartMatchNotification[] @relation("NotifGeo")
  waitingTimeReports      WaitingTimeReport[]      @relation("WaitTimeGeo")
  diagnosticProviders     DiagnosticProvider[]
  hospitals               Hospital[]
  tpaPresence             TpaGeographyPresence[]

  @@unique([slug, level, parentId])
  @@index([parentId])
  @@index([slug, isActive])
  @@index([level, isActive])
  @@map("geographies")
}

model DoctorProvider {
  id                      Int                      @id @default(autoincrement())
  slug                    String                   @unique @db.VarChar(255)
  name                    String                   @db.VarChar(500)
  email                   String?                  @unique @db.VarChar(200)
  licenseNumber           String?                  @map("license_number") @db.VarChar(100)
  licensingBody           String?                  @map("licensing_body") @db.VarChar(200)
  bio                     String?
  qualifications          String[]
  experienceYears         Int?                     @map("experience_years")
  contactInfo             Json                     @default("{}") @map("contact_info")
  profileImage            String?                  @map("profile_image") @db.VarChar(500)
  // Media gallery
  coverImage              String?                  @map("cover_image") @db.VarChar(500)
  images                  String[]                 @default([])
  videoUrl                String?                  @map("video_url") @db.VarChar(500)
  videoThumbnail          String?                  @map("video_thumbnail") @db.VarChar(500)
  geographyId             Int?                     @map("geography_id")
  isVerified              Boolean                  @default(false) @map("is_verified")
  verificationDate        DateTime?                @map("verification_date") @db.Timestamptz(6)
  subscriptionTier        SubscriptionTier         @default(free) @map("subscription_tier")
  rating                  Decimal?                 @db.Decimal(2, 1)
  reviewCount             Int                      @default(0) @map("review_count")
  consultationFee         Decimal?                 @map("consultation_fee") @db.Decimal(10, 2)
  feeCurrency             String                   @default("INR") @map("fee_currency") @db.VarChar(3)
  availableOnline         Boolean                  @default(false) @map("available_online")
  schemaMarkup            Json?                    @map("schema_markup")
  createdAt               DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                 @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  badgeScore              Decimal?                 @map("badge_score") @db.Decimal(5, 2)
  badgeRank               Int?                     @map("badge_rank")
  badgeLabel              String?                  @map("badge_label") @db.VarChar(50)
  badgeCityId             Int?                     @map("badge_city_id")
  badgeUpdated            DateTime?                @map("badge_updated") @db.Timestamptz(6)
  conditionReviewers      ConditionReviewer[]
  specialties             DoctorSpecialty[]
  badgeCity               Geography?               @relation("BadgeCity", fields: [badgeCityId], references: [id])
  geography               Geography?               @relation(fields: [geographyId], references: [id])
  encounters              Encounter[]
  leadCredits             LeadCredit[]
  leadLogs                LeadLog[]
  licenseVerifications    LicenseVerification[]
  reviewedContent         LocalizedContent[]       @relation("ContentReviewer")
  onboardingSteps         OnboardingStep[]
  providerAnalytics       ProviderAnalytics[]
  providerSubscription    ProviderSubscription?
  smartMatchNotifications SmartMatchNotification[]
  teleconsultations       Teleconsultation[]
  waitingTimeReports      WaitingTimeReport[]
  hospitalDoctors         HospitalDoctor[]
  reviewedPageContent     ConditionPageContent[]   @relation("PageContentReviewer")
  paymentNotifications    PaymentNotification[]

  @@index([geographyId, isVerified])
  @@index([subscriptionTier])
  @@index([rating(sort: Desc)])
  @@index([geographyId, subscriptionTier, isVerified])
  @@index([isVerified, subscriptionTier])
  @@index([createdAt(sort: Desc)])
  @@index([badgeScore(sort: Desc)])
  @@map("doctors_providers")
}

model DoctorSpecialty {
  id          Int              @id @default(autoincrement())
  doctorId    Int              @map("doctor_id")
  conditionId Int              @map("condition_id")
  isPrimary   Boolean          @default(false) @map("is_primary")
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  condition   MedicalCondition @relation(fields: [conditionId], references: [id], onDelete: Cascade)
  doctor      DoctorProvider   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, conditionId])
  @@index([conditionId])
  @@map("doctor_specialties")
}

model LocalizedContent {
  id               Int                @id @default(autoincrement())
  conditionId      Int                @map("condition_id")
  languageCode     String             @map("language_code") @db.VarChar(5)
  geographyId      Int?               @map("geography_id")
  title            String             @db.VarChar(500)
  description      String
  localizedAdvice  String?            @map("localized_advice")
  localFactors     Json               @default("{}") @map("local_factors")
  consultationTips String?            @map("consultation_tips")
  metaTitle        String?            @map("meta_title") @db.VarChar(160)
  metaDescription  String?            @map("meta_description") @db.VarChar(300)
  status           ContentStatus      @default(ai_draft)
  reviewedBy       Int?               @map("reviewed_by")
  reviewedAt       DateTime?          @map("reviewed_at") @db.Timestamptz(6)
  aiModelUsed      String?            @map("ai_model_used") @db.VarChar(100)
  wordCount        Int?               @map("word_count")
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  condition        MedicalCondition   @relation(fields: [conditionId], references: [id], onDelete: Cascade)
  geography        Geography?         @relation(fields: [geographyId], references: [id])
  language         Language           @relation(fields: [languageCode], references: [code])
  reviewer         DoctorProvider?    @relation("ContentReviewer", fields: [reviewedBy], references: [id])
  translationQueue TranslationQueue[]

  @@unique([conditionId, languageCode, geographyId])
  @@index([status])
  @@index([languageCode, status])
  @@index([conditionId, languageCode, status])
  @@index([geographyId, languageCode])
  @@map("localized_content")
}

model ConditionReviewer {
  id          Int              @id @default(autoincrement())
  conditionId Int              @map("condition_id")
  doctorId    Int              @map("doctor_id")
  geographyId Int?             @map("geography_id")
  isPrimary   Boolean          @default(true) @map("is_primary")
  reviewDate  DateTime         @default(now()) @map("review_date") @db.Timestamptz(6)
  reviewNotes String?          @map("review_notes")
  condition   MedicalCondition @relation(fields: [conditionId], references: [id], onDelete: Cascade)
  doctor      DoctorProvider   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  geography   Geography?       @relation(fields: [geographyId], references: [id])

  @@unique([conditionId, doctorId, geographyId])
  @@index([conditionId])
  @@index([doctorId])
  @@index([geographyId])
  @@map("condition_reviewers")
}

model AiAnalysisCache {
  id             Int       @id @default(autoincrement())
  inputHash      String    @unique @map("input_hash") @db.VarChar(64)
  conditionSlug  String?   @map("condition_slug") @db.VarChar(255)
  extractedData  Json      @map("extracted_data")
  summaryText    String?   @map("summary_text")
  specialistType String?   @map("specialist_type") @db.VarChar(100)
  severityLevel  String?   @map("severity_level") @db.VarChar(20)
  matchedDoctors Int[]     @map("matched_doctors")
  modelUsed      String?   @map("model_used") @db.VarChar(100)
  tokenCount     Int?      @map("token_count")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt      DateTime? @map("expires_at") @db.Timestamptz(6)

  @@map("ai_analysis_cache")
}

model PageCache {
  id           Int      @id @default(autoincrement())
  cacheKey     String   @unique @map("cache_key") @db.VarChar(500)
  htmlFragment String   @map("html_fragment")
  etag         String?  @db.VarChar(64)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt    DateTime @map("expires_at") @db.Timestamptz(6)

  @@map("page_cache")
}

model UiTranslation {
  id           Int      @id @default(autoincrement())
  languageCode String   @map("language_code") @db.VarChar(5)
  namespace    String   @default("common") @db.VarChar(100)
  key          String   @db.VarChar(255)
  value        String
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  language     Language @relation(fields: [languageCode], references: [code])

  @@unique([languageCode, namespace, key])
  @@map("ui_translations")
}

model SitemapEntry {
  id           Int               @id @default(autoincrement())
  urlPath      String            @unique @map("url_path") @db.VarChar(500)
  sitemapIndex Int               @default(0) @map("sitemap_index")
  changefreq   String            @default("weekly") @db.VarChar(20)
  priority     Decimal           @default(0.7) @db.Decimal(2, 1)
  lastModified DateTime          @default(now()) @map("last_modified") @db.Timestamptz(6)
  languageCode String?           @map("language_code") @db.VarChar(5)
  conditionId  Int?              @map("condition_id")
  geographyId  Int?              @map("geography_id")
  condition    MedicalCondition? @relation(fields: [conditionId], references: [id])
  geography    Geography?        @relation(fields: [geographyId], references: [id])
  language     Language?         @relation(fields: [languageCode], references: [code])

  @@map("sitemap_entries")
}

model PinnedCondition {
  id           Int              @id @default(autoincrement())
  geographyId  Int              @map("geography_id")
  conditionId  Int              @map("condition_id")
  displayOrder Int              @default(0) @map("display_order")
  pinnedBy     String?          @map("pinned_by") @db.VarChar(255)
  reason       String?
  isActive     Boolean          @default(true) @map("is_active")
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  condition    MedicalCondition @relation(fields: [conditionId], references: [id], onDelete: Cascade)
  geography    Geography        @relation(fields: [geographyId], references: [id], onDelete: Cascade)

  @@unique([geographyId, conditionId])
  @@map("pinned_conditions")
}

model GeoAnalytics {
  id             Int        @id @default(autoincrement())
  countryCode    String     @map("country_code") @db.VarChar(5)
  citySlug       String?    @map("city_slug") @db.VarChar(255)
  geographyId    Int?       @map("geography_id")
  visitDate      DateTime   @map("visit_date") @db.Date
  visitCount     Int        @default(1) @map("visit_count")
  uniqueVisitors Int        @default(1) @map("unique_visitors")
  topConditions  String[]   @map("top_conditions") @db.VarChar(255)
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  geography      Geography? @relation(fields: [geographyId], references: [id])

  @@unique([countryCode, citySlug, visitDate])
  @@map("geo_analytics")
}

model ReportUpload {
  id              String           @id @default(uuid()) @db.Uuid
  sessionHash     String           @map("session_hash") @db.VarChar(64)
  filePath        String           @map("file_path") @db.VarChar(500)
  fileType        ReportType       @default(other) @map("file_type")
  fileSizeBytes   Int?             @map("file_size_bytes")
  mimeType        String?          @map("mime_type") @db.VarChar(100)
  ocrText         String?          @map("ocr_text")
  isSanitized     Boolean          @default(false) @map("is_sanitized")
  encryptionIv    String?          @map("encryption_iv") @db.VarChar(64)
  expiresAt       DateTime         @map("expires_at") @db.Timestamptz(6)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  analysisResults AnalysisResult[]

  @@map("report_uploads")
}

model AnalysisResult {
  id                String           @id @default(uuid()) @db.Uuid
  uploadId          String?          @map("upload_id") @db.Uuid
  sessionHash       String           @map("session_hash") @db.VarChar(64)
  primaryIndicators Json             @default("[]") @map("primary_indicators")
  specialtyRequired String?          @map("specialty_required") @db.VarChar(100)
  conditionSlug     String?          @map("condition_slug") @db.VarChar(255)
  urgencyLevel      UrgencyLevel     @default(routine) @map("urgency_level")
  plainEnglish      String?          @map("plain_english")
  questionsToAsk    Json             @default("[]") @map("questions_to_ask")
  lifestyleFactors  Json             @default("[]") @map("lifestyle_factors")
  fullDossier       Json             @default("{}") @map("full_dossier")
  confidenceScore   Decimal          @default(0) @map("confidence_score") @db.Decimal(4, 2)
  needsReview       Boolean          @default(false) @map("needs_review")
  reviewedBy        String?          @map("reviewed_by") @db.VarChar(255)
  reviewedAt        DateTime?        @map("reviewed_at") @db.Timestamptz(6)
  reviewNotes       String?          @map("review_notes")
  matchedDoctorIds  Int[]            @default([]) @map("matched_doctor_ids")
  matchGeographyId  Int?             @map("match_geography_id")
  modelUsed         String?          @map("model_used") @db.VarChar(100)
  tokenCount        Int?             @map("token_count")
  processingTimeMs  Int?             @map("processing_time_ms")
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  matchGeography    Geography?       @relation("AnalysisGeo", fields: [matchGeographyId], references: [id])
  upload            ReportUpload?    @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  encounters        Encounter[]
  healthTimelines   HealthTimeline[]
  leadLogs          LeadLog[]
  vaultFiles        VaultFile[]

  @@index([sessionHash])
  @@index([conditionSlug])
  @@index([createdAt(sort: Desc)])
  @@index([uploadId, createdAt(sort: Desc)])
  @@map("analysis_results")
}

model HealthTimeline {
  id             String         @id @default(uuid()) @db.Uuid
  sessionHash    String         @map("session_hash") @db.VarChar(64)
  analysisId     String         @map("analysis_id") @db.Uuid
  indicatorName  String         @map("indicator_name") @db.VarChar(255)
  indicatorValue Decimal?       @map("indicator_value") @db.Decimal(10, 2)
  indicatorUnit  String?        @map("indicator_unit") @db.VarChar(50)
  recordedDate   DateTime       @default(now()) @map("recorded_date") @db.Date
  trendDirection String?        @map("trend_direction") @db.VarChar(20)
  trendPercent   Decimal?       @map("trend_percent") @db.Decimal(5, 2)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  analysis       AnalysisResult @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([sessionHash, indicatorName])
  @@index([recordedDate(sort: Desc)])
  @@map("health_timelines")
}

model WaitingTimeReport {
  id          Int            @id @default(autoincrement())
  doctorId    Int            @map("doctor_id")
  geographyId Int?           @map("geography_id")
  waitMinutes Int            @map("wait_minutes")
  visitDate   DateTime       @default(now()) @map("visit_date") @db.Date
  visitType   String         @default("in-person") @map("visit_type") @db.VarChar(50)
  sessionHash String?        @map("session_hash") @db.VarChar(64)
  isVerified  Boolean        @default(false) @map("is_verified")
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  doctor      DoctorProvider @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  geography   Geography?     @relation("WaitTimeGeo", fields: [geographyId], references: [id])

  @@index([doctorId])
  @@index([visitDate(sort: Desc)])
  @@map("waiting_time_reports")
}

model PromptLabEntry {
  id             String   @id @default(uuid()) @db.Uuid
  promptName     String   @map("prompt_name") @db.VarChar(255)
  promptType     String   @map("prompt_type") @db.VarChar(100)
  systemPrompt   String   @map("system_prompt")
  sampleInput    String?  @map("sample_input")
  expectedOutput Json?    @map("expected_output")
  actualOutput   Json?    @map("actual_output")
  modelUsed      String?  @map("model_used") @db.VarChar(100)
  tokenCount     Int?     @map("token_count")
  latencyMs      Int?     @map("latency_ms")
  score          Decimal? @db.Decimal(4, 2)
  isActive       Boolean  @default(false) @map("is_active")
  createdBy      String?  @map("created_by") @db.VarChar(255)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("prompt_lab_entries")
}

model TranslationQueue {
  id                 Int              @id @default(autoincrement())
  localizedContentId Int              @map("localized_content_id")
  sourceLanguage     String           @default("en") @map("source_language") @db.VarChar(5)
  targetLanguage     String           @map("target_language") @db.VarChar(5)
  masterText         String           @map("master_text")
  translatedText     String           @map("translated_text")
  correctedText      String?          @map("corrected_text")
  status             QueueStatus      @default(pending)
  reviewedBy         String?          @map("reviewed_by") @db.VarChar(255)
  reviewedAt         DateTime?        @map("reviewed_at") @db.Timestamptz(6)
  aiModelUsed        String?          @map("ai_model_used") @db.VarChar(100)
  qualityScore       Decimal?         @map("quality_score") @db.Decimal(4, 2)
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  localizedContent   LocalizedContent @relation(fields: [localizedContentId], references: [id], onDelete: Cascade)
  targetLang         Language         @relation("TranslationLang", fields: [targetLanguage], references: [code])

  @@index([status])
  @@index([targetLanguage, status])
  @@map("translation_queue")
}

model SeasonalTrigger {
  id               Int              @id @default(autoincrement())
  geographyId      Int              @map("geography_id")
  conditionId      Int              @map("condition_id")
  triggerType      String           @map("trigger_type") @db.VarChar(50)
  triggerThreshold Json             @default("{}") @map("trigger_threshold")
  highlightMessage String?          @map("highlight_message")
  specialistType   String?          @map("specialist_type") @db.VarChar(100)
  isActive         Boolean          @default(true) @map("is_active")
  seasonStart      String?          @map("season_start") @db.VarChar(5)
  seasonEnd        String?          @map("season_end") @db.VarChar(5)
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  condition        MedicalCondition @relation(fields: [conditionId], references: [id], onDelete: Cascade)
  geography        Geography        @relation(fields: [geographyId], references: [id], onDelete: Cascade)

  @@unique([geographyId, conditionId, triggerType])
  @@map("seasonal_triggers")
}

model SubscriptionPlan {
  id                    Int                    @id @default(autoincrement())
  planName              String                 @map("plan_name") @db.VarChar(100)
  planSlug              String                 @unique @map("plan_slug") @db.VarChar(50)
  tier                  SubscriptionTier
  maxConditions         Int                    @default(2) @map("max_conditions")
  maxLeadCredits        Int                    @default(0) @map("max_lead_credits")
  hasAiBio              Boolean                @default(false) @map("has_ai_bio")
  hasLeadScoring        Boolean                @default(false) @map("has_lead_scoring")
  hasTelelink           Boolean                @default(false) @map("has_telelink")
  hasPriorityListing    Boolean                @default(false) @map("has_priority_listing")
  hasAnalytics          Boolean                @default(false) @map("has_analytics")
  basePriceUsd          Decimal                @default(0) @map("base_price_usd") @db.Decimal(10, 2)
  billingInterval       String                 @default("monthly") @map("billing_interval") @db.VarChar(20)
  stripePriceId         String?                @map("stripe_price_id") @db.VarChar(255)
  stripePriceIdTest     String?                @map("stripe_price_id_test") @db.VarChar(255)
  isActive              Boolean                @default(true) @map("is_active")
  createdAt             DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  providerSubscriptions ProviderSubscription[]
  regionalPricing       RegionalPricing[]

  @@map("subscription_plans")
}

model RegionalPricing {
  id            Int              @id @default(autoincrement())
  planId        Int              @map("plan_id")
  countryCode   String           @map("country_code") @db.VarChar(5)
  currency      String           @db.VarChar(3)
  price         Decimal          @db.Decimal(10, 2)
  stripePriceId String?          @map("stripe_price_id") @db.VarChar(255)
  isActive      Boolean          @default(true) @map("is_active")
  plan          SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, countryCode])
  @@map("regional_pricing")
}

model ProviderSubscription {
  id                   String             @id @default(uuid()) @db.Uuid
  doctorId             Int                @unique @map("doctor_id")
  planId               Int                @map("plan_id")
  status               SubscriptionStatus @default(trial)
  stripeCustomerId     String?            @map("stripe_customer_id") @db.VarChar(255)
  stripeSubscriptionId String?            @map("stripe_subscription_id") @db.VarChar(255)
  currentPeriodStart   DateTime?          @map("current_period_start") @db.Timestamptz(6)
  currentPeriodEnd     DateTime?          @map("current_period_end") @db.Timestamptz(6)
  trialEndsAt          DateTime?          @map("trial_ends_at") @db.Timestamptz(6)
  cancelledAt          DateTime?          @map("cancelled_at") @db.Timestamptz(6)
  conditionsUsed       Int                @default(0) @map("conditions_used")
  leadCreditsUsed      Int                @default(0) @map("lead_credits_used")
  leadCreditsTotal     Int                @default(0) @map("lead_credits_total")
  countryCode          String?            @map("country_code") @db.VarChar(5)
  currency             String             @default("USD") @db.VarChar(3)
  amountPaid           Decimal            @default(0) @map("amount_paid") @db.Decimal(10, 2)
  taxAmount            Decimal            @default(0) @map("tax_amount") @db.Decimal(10, 2)
  taxType              String?            @map("tax_type") @db.VarChar(20)
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  doctor               DoctorProvider     @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  plan                 SubscriptionPlan   @relation(fields: [planId], references: [id])

  @@map("provider_subscriptions")
}

model OnboardingStep {
  id                 String               @id @default(uuid()) @db.Uuid
  doctorId           Int                  @map("doctor_id")
  status             OnboardingStatusEnum @default(pending)
  stepProfile        Boolean              @default(false) @map("step_profile")
  stepLicense        Boolean              @default(false) @map("step_license")
  stepBio            Boolean              @default(false) @map("step_bio")
  stepConditions     Boolean              @default(false) @map("step_conditions")
  stepSubscription   Boolean              @default(false) @map("step_subscription")
  currentStep        Int                  @default(1) @map("current_step")
  rawBioInput        String?              @map("raw_bio_input")
  aiEnhancedBio      String?              @map("ai_enhanced_bio")
  selectedConditions Int[]                @default([]) @map("selected_conditions")
  startedAt          DateTime             @default(now()) @map("started_at") @db.Timestamptz(6)
  completedAt        DateTime?            @map("completed_at") @db.Timestamptz(6)
  updatedAt          DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  doctor             DoctorProvider       @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([status])
  @@map("onboarding_steps")
}

model LicenseVerification {
  id                String                 @id @default(uuid()) @db.Uuid
  doctorId          Int                    @map("doctor_id")
  registryType      String                 @map("registry_type") @db.VarChar(50)
  licenseNumber     String                 @map("license_number") @db.VarChar(100)
  countryCode       String                 @map("country_code") @db.VarChar(5)
  status            VerificationStatusEnum @default(pending)
  apiResponse       Json                   @default("{}") @map("api_response")
  verifiedName      String?                @map("verified_name") @db.VarChar(500)
  verifiedSpecialty String?                @map("verified_specialty") @db.VarChar(200)
  verifiedStatus    String?                @map("verified_status") @db.VarChar(100)
  matchConfidence   Decimal?               @map("match_confidence") @db.Decimal(4, 2)
  reviewedBy        String?                @map("reviewed_by") @db.VarChar(255)
  reviewedAt        DateTime?              @map("reviewed_at") @db.Timestamptz(6)
  reviewNotes       String?                @map("review_notes")
  rejectionReason   String?                @map("rejection_reason")
  verifiedAt        DateTime?              @map("verified_at") @db.Timestamptz(6)
  expiresAt         DateTime?              @map("expires_at") @db.Timestamptz(6)
  createdAt         DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  doctor            DoctorProvider         @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([status])
  @@index([countryCode, status])
  @@map("license_verifications")
}

model LeadLog {
  id                String             @id @default(uuid()) @db.Uuid
  doctorId          Int                @map("doctor_id")
  analysisId        String?            @map("analysis_id") @db.Uuid
  sessionHash       String?            @map("session_hash") @db.VarChar(64)
  conditionSlug     String?            @map("condition_slug") @db.VarChar(255)
  specialtyMatched  String?            @map("specialty_matched") @db.VarChar(100)
  geographyId       Int?               @map("geography_id")
  intentLevel       LeadIntent         @default(medium) @map("intent_level")
  intentScore       Decimal            @default(0.5) @map("intent_score") @db.Decimal(4, 2)
  scoringFactors    Json               @default("{}") @map("scoring_factors")
  isViewed          Boolean            @default(false) @map("is_viewed")
  viewedAt          DateTime?          @map("viewed_at") @db.Timestamptz(6)
  isContacted       Boolean            @default(false) @map("is_contacted")
  contactedAt       DateTime?          @map("contacted_at") @db.Timestamptz(6)
  contactRevealed   Boolean            @default(false) @map("contact_revealed")
  creditsSpent      Int                @default(0) @map("credits_spent")
  outcome           String?            @db.VarChar(50)
  outcomeNotes      String?            @map("outcome_notes")
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  leadCredits       LeadCredit[]
  analysis          AnalysisResult?    @relation(fields: [analysisId], references: [id])
  doctor            DoctorProvider     @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  geography         Geography?         @relation("LeadGeo", fields: [geographyId], references: [id])
  teleconsultations Teleconsultation[]

  @@index([doctorId, createdAt(sort: Desc)])
  @@index([sessionHash])
  @@index([intentLevel])
  @@index([doctorId, intentLevel])
  @@index([analysisId])
  @@index([createdAt(sort: Desc)])
  @@index([doctorId, isViewed])
  @@index([conditionSlug])
  @@index([geographyId])
  @@map("lead_logs")
}

model LeadCredit {
  id              Int            @id @default(autoincrement())
  doctorId        Int            @map("doctor_id")
  transactionType String         @map("transaction_type") @db.VarChar(20)
  amount          Int
  balanceAfter    Int            @default(0) @map("balance_after")
  leadLogId       String?        @map("lead_log_id") @db.Uuid
  description     String?        @db.VarChar(255)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  doctor          DoctorProvider @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  leadLog         LeadLog?       @relation(fields: [leadLogId], references: [id])

  @@index([doctorId, createdAt(sort: Desc)])
  @@map("lead_credits")
}

model ProviderAnalytics {
  id                Int            @id @default(autoincrement())
  doctorId          Int            @map("doctor_id")
  date              DateTime       @default(now()) @db.Date
  profileViews      Int            @default(0) @map("profile_views")
  searchAppearances Int            @default(0) @map("search_appearances")
  conditionSlug     String?        @map("condition_slug") @db.VarChar(255)
  geographyId       Int?           @map("geography_id")
  leadCount         Int            @default(0) @map("lead_count")
  contactReveals    Int            @default(0) @map("contact_reveals")
  teleconsultCount  Int            @default(0) @map("teleconsult_count")
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  doctor            DoctorProvider @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  geography         Geography?     @relation("AnalyticsGeo", fields: [geographyId], references: [id])

  @@unique([doctorId, date, conditionSlug])
  @@index([doctorId, date(sort: Desc)])
  @@index([geographyId, date(sort: Desc)])
  @@index([conditionSlug, date(sort: Desc)])
  @@map("provider_analytics")
}

model Teleconsultation {
  id              String            @id @default(uuid()) @db.Uuid
  doctorId        Int               @map("doctor_id")
  leadLogId       String?           @map("lead_log_id") @db.Uuid
  sessionHash     String?           @map("session_hash") @db.VarChar(64)
  scheduledAt     DateTime          @map("scheduled_at") @db.Timestamptz(6)
  durationMinutes Int               @default(15) @map("duration_minutes")
  status          TeleconsultStatus @default(scheduled)
  videoProvider   String            @default("daily") @map("video_provider") @db.VarChar(50)
  roomUrl         String?           @map("room_url") @db.VarChar(500)
  roomToken       String?           @map("room_token")
  consultationFee Decimal           @default(0) @map("consultation_fee") @db.Decimal(10, 2)
  platformFee     Decimal           @default(0) @map("platform_fee") @db.Decimal(10, 2)
  currency        String            @default("USD") @db.VarChar(3)
  isPaid          Boolean           @default(false) @map("is_paid")
  stripePaymentId String?           @map("stripe_payment_id") @db.VarChar(255)
  startedAt       DateTime?         @map("started_at") @db.Timestamptz(6)
  endedAt         DateTime?         @map("ended_at") @db.Timestamptz(6)
  doctorNotes     String?           @map("doctor_notes")
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  doctor          DoctorProvider    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  leadLog         LeadLog?          @relation(fields: [leadLogId], references: [id])

  @@index([doctorId, scheduledAt])
  @@index([status, scheduledAt])
  @@index([sessionHash])
  @@map("teleconsultations")
}

