  vault             HealthVault     @relation(fields: [vaultId], references: [id], onDelete: Cascade)

  @@map("vault_files")
}

model Encounter {
  id              String          @id @default(uuid()) @db.Uuid
  sessionHash     String          @map("session_hash") @db.VarChar(64)
  doctorId        Int             @map("doctor_id")
  vaultId         String?         @map("vault_id") @db.Uuid
  analysisId      String?         @map("analysis_id") @db.Uuid
  leadLogId       String?         @map("lead_log_id") @db.Uuid
  conditionSlug   String?         @map("condition_slug") @db.VarChar(255)
  geographyId     Int?            @map("geography_id")
  enquiryType     String          @default("opinion") @db.VarChar(50)
  urgency         UrgencyLevel    @default(routine)
  patientLanguage String          @default("en") @map("patient_language") @db.VarChar(5)
  doctorLanguage  String          @default("en") @map("doctor_language") @db.VarChar(5)
  status          EncounterStatus @default(pending)
  caseDossier     Json            @default("{}") @map("case_dossier")
  doctorNotes     String?         @map("doctor_notes")
  doctorOpinion   String?         @map("doctor_opinion")
  aiSecondOpinion String?         @map("ai_second_opinion")
  respondedAt     DateTime?       @map("responded_at") @db.Timestamptz(6)
  completedAt     DateTime?       @map("completed_at") @db.Timestamptz(6)
  expiresAt       DateTime?       @map("expires_at") @db.Timestamptz(6)
  responseTimeMs  Int?            @map("response_time_ms")
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  chatMessages    ChatMessage[]
  analysis        AnalysisResult? @relation(fields: [analysisId], references: [id])
  doctor          DoctorProvider  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  geography       Geography?      @relation("EncounterGeo", fields: [geographyId], references: [id])
  vault           HealthVault?    @relation(fields: [vaultId], references: [id])
  enquiryLogs     EnquiryLog[]

  @@index([doctorId, status])
  @@index([sessionHash])
  @@index([status, createdAt(sort: Desc)])
  @@index([conditionSlug])
  @@map("encounters")
}

model ChatMessage {
  id               String      @id @default(uuid()) @db.Uuid
  encounterId      String      @map("encounter_id") @db.Uuid
  senderType       String      @map("sender_type") @db.VarChar(20)
  senderId         String?     @map("sender_id") @db.VarChar(100)
  content          String
  contentType      MessageType @default(text) @map("content_type")
  fileUrl          String?     @map("file_url") @db.VarChar(1000)
  originalLanguage String?     @map("original_language") @db.VarChar(5)
  translatedText   String?     @map("translated_text")
  translatedTo     String?     @map("translated_to") @db.VarChar(5)
  translationModel String?     @map("translation_model") @db.VarChar(100)
  isRead           Boolean     @default(false) @map("is_read")
  readAt           DateTime?   @map("read_at") @db.Timestamptz(6)
  isDeleted        Boolean     @default(false) @map("is_deleted")
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  encounter        Encounter   @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([encounterId, createdAt])
  @@map("chat_messages")
}

