model VaultFile {
  id                String          @id @default(uuid()) @db.Uuid
  vaultId           String          @map("vault_id") @db.Uuid
  fileName          String          @map("file_name") @db.VarChar(500)
  fileType          ReportType      @default(other) @map("file_type")
  mimeType          String?         @map("mime_type") @db.VarChar(100)
  fileSizeBytes     Int?            @map("file_size_bytes")
  driveFileId       String?         @map("drive_file_id") @db.VarChar(255)
  driveWebLink      String?         @map("drive_web_link") @db.VarChar(1000)
  thumbnailUrl      String?         @map("thumbnail_url") @db.VarChar(1000)
  analysisId        String?         @map("analysis_id") @db.Uuid
  aiSummary         String?         @map("ai_summary")
  ocrText           String?         @map("ocr_text")
  isProcessed       Boolean         @default(false) @map("is_processed")
  sharedWithDoctors Int[]           @default([]) @map("shared_with_doctors")
  accessExpiresAt   DateTime?       @map("access_expires_at") @db.Timestamptz(6)
  isArchived        Boolean         @default(false) @map("is_archived")
  uploadDate        DateTime        @default(now()) @map("upload_date") @db.Timestamptz(6)
