model DiagnosticCategory {
  id              Int                  @id @default(autoincrement())
  slug            String               @unique @db.VarChar(100)
  name            String               @db.VarChar(200)
  description     String?
  icon            String?              @db.VarChar(50) // emoji or icon name
  parentId        Int?                 @map("parent_id")
  displayOrder    Int                  @default(0) @map("display_order")
  metaTitle       String?              @map("meta_title") @db.VarChar(160)
  metaDescription String?              @map("meta_description") @db.VarChar(300)
  isActive        Boolean              @default(true) @map("is_active")
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  parent          DiagnosticCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children        DiagnosticCategory[] @relation("CategoryHierarchy")
  tests           DiagnosticTest[]

  @@index([parentId])
  @@index([isActive, displayOrder])
  @@map("diagnostic_categories")
}

model DiagnosticTest {
  id                      Int                     @id @default(autoincrement())
  slug                    String                  @unique @db.VarChar(255)
  name                    String                  @db.VarChar(300)
  shortName               String?                 @map("short_name") @db.VarChar(100)
  aliases                 String[]                @default([]) // alternate names for search
  categoryId              Int                     @map("category_id")
  testType                DiagnosticTestType      @default(lab_test) @map("test_type")
  description             String?
  sampleType              String?                 @map("sample_type") @db.VarChar(100) // blood, urine, tissue, etc.
  fastingRequired         Boolean                 @default(false) @map("fasting_required")
  fastingHours            Int?                    @map("fasting_hours")
  preparationInstructions String?                 @map("preparation_instructions")
  reportTimeHours         Int?                    @map("report_time_hours") // typical turnaround
  normalRanges            Json                    @default("{}") @map("normal_ranges") // age/gender specific ranges
  relatedConditions       String[]                @default([]) @map("related_conditions") // condition slugs
  relatedTests            Int[]                   @default([]) @map("related_tests") // test IDs often ordered together
  keywords                String[]                @default([]) // SEO keywords
  bodySystem              String?                 @map("body_system") @db.VarChar(100)
  specialistType          String?                 @map("specialist_type") @db.VarChar(100)
  homeCollectionPossible  Boolean                 @default(true) @map("home_collection_possible")
  metaTitle               String?                 @map("meta_title") @db.VarChar(160)
  metaDescription         String?                 @map("meta_description") @db.VarChar(300)
  schemaMarkup            Json?                   @map("schema_markup")
  avgPriceInr             Decimal?                @map("avg_price_inr") @db.Decimal(10, 2)
  avgPriceUsd             Decimal?                @map("avg_price_usd") @db.Decimal(10, 2)
  isActive                Boolean                 @default(true) @map("is_active")
  isFeatured              Boolean                 @default(false) @map("is_featured")
  searchVolume            Int?                    @map("search_volume") // monthly search volume
  createdAt               DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  category                DiagnosticCategory      @relation(fields: [categoryId], references: [id])
  prices                  DiagnosticTestPrice[]
  packageTests            DiagnosticPackageTest[]
  bookings                DiagnosticBooking[]
  localizedContent        DiagnosticTestContent[]

  @@index([categoryId, isActive])
  @@index([testType, isActive])
  @@index([isFeatured, isActive])
  @@index([bodySystem])
  @@map("diagnostic_tests")
}

model DiagnosticTestContent {
  id              Int            @id @default(autoincrement())
  testId          Int            @map("test_id")
  languageCode    String         @map("language_code") @db.VarChar(5)
  geographyId     Int?           @map("geography_id")
  title           String         @db.VarChar(300)
  description     String?
  preparation     String? // localized preparation instructions
  interpretation  String? // how to read results
  whenToGetTested String?        @map("when_to_get_tested")
  metaTitle       String?        @map("meta_title") @db.VarChar(160)
  metaDescription String?        @map("meta_description") @db.VarChar(300)
  status          ContentStatus  @default(ai_draft)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  test            DiagnosticTest @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@unique([testId, languageCode, geographyId])
  @@index([languageCode, status])
  @@map("diagnostic_test_content")
}

