// ════════════════════════════════════════════════════════════════════════════════
// HOSPITALS SYSTEM
// ════════════════════════════════════════════════════════════════════════════════

model Hospital {
  id              Int          @id @default(autoincrement())
  slug            String       @unique @db.VarChar(255)
  name            String       @db.VarChar(500)
  hospitalType    HospitalType @default(private) @map("hospital_type")
  establishedYear Int?         @map("established_year")
  description     String?
  tagline         String?      @db.VarChar(300)
  logo            String?      @db.VarChar(500)
  coverImage      String?      @map("cover_image") @db.VarChar(500)
  images          String[]     @default([])
  videoUrl        String?      @map("video_url") @db.VarChar(500)

  // Location
  geographyId Int?     @map("geography_id")
  address     String?  @db.VarChar(500)
  city        String?  @db.VarChar(100)
  state       String?  @db.VarChar(100)
  country     String?  @db.VarChar(100)
  pincode     String?  @db.VarChar(20)
  latitude    Decimal? @db.Decimal(10, 7)
  longitude   Decimal? @db.Decimal(10, 7)

  // Contact
  phone          String? @db.VarChar(50)
  emergencyPhone String? @map("emergency_phone") @db.VarChar(50)
  email          String? @db.VarChar(200)
  website        String? @db.VarChar(500)
  googlePlaceId  String? @unique @map("google_place_id") @db.VarChar(255)

  // Capacity & Infrastructure
  bedCount                 Int?    @map("bed_count")
  icuBeds                  Int?    @map("icu_beds")
  operationTheaters        Int?    @map("operation_theaters")
  emergencyBeds            Int?    @map("emergency_beds")
  ambulanceCount           Int?    @map("ambulance_count")
  bloodBank                Boolean @default(false) @map("blood_bank")
  pharmacy24x7             Boolean @default(false) @map("pharmacy_24x7")
  cafeteria                Boolean @default(false)
  parking                  Boolean @default(false)
  wifi                     Boolean @default(false)
  airportPickup            Boolean @default(false) @map("airport_pickup")
  translatorServices       Boolean @default(false) @map("translator_services")
  internationalPatientDesk Boolean @default(false) @map("international_patient_desk")

  // Accreditations & Recognition
  accreditations String[] @default([]) // NABH, JCI, NABL, ISO, etc.
  awards         Json     @default("[]") // Array of {year, award, org}
  rankings       Json     @default("[]") // Array of {year, rank, category, org}

  // Ownership & Management
  ownershipType      String? @map("ownership_type") @db.VarChar(100) // Trust, Corporate, Government, Public
  parentOrganization String? @map("parent_organization") @db.VarChar(300)
  ownerName          String? @map("owner_name") @db.VarChar(300)
  managingDirector   String? @map("managing_director") @db.VarChar(300)
  ceo                String? @db.VarChar(300)
  medicalDirector    String? @map("medical_director") @db.VarChar(300)

  // Notable Info
  notablePatients Json @default("[]") @map("notable_patients") // Array of {name, type, year, treatedBy, condition}
  scandals        Json @default("[]") // Array of {year, title, description, outcome}
  mediaFeatures   Json @default("[]") @map("media_features") // Array of {title, source, url, date}

  // Reviews & Ratings
  overallRating       Decimal? @map("overall_rating") @db.Decimal(2, 1)
  domesticRating      Decimal? @map("domestic_rating") @db.Decimal(2, 1)
  internationalRating Decimal? @map("international_rating") @db.Decimal(2, 1)
  reviewCount         Int      @default(0) @map("review_count")
  domesticReviewCount Int      @default(0) @map("domestic_review_count")
  intlReviewCount     Int      @default(0) @map("intl_review_count")

  // Pros/Cons Summary (AI-generated from reviews)
  prosForPatients     String[] @default([]) @map("pros_for_patients")
  consForPatients     String[] @default([]) @map("cons_for_patients")
  domesticPatientTips String?  @map("domestic_patient_tips")
  intlPatientTips     String?  @map("intl_patient_tips")

  // SEO
  metaTitle       String?  @map("meta_title") @db.VarChar(160)
  metaDescription String?  @map("meta_description") @db.VarChar(300)
  keywords        String[] @default([])
  schemaMarkup    Json?    @map("schema_markup")

  // Status
  isVerified Boolean  @default(false) @map("is_verified")
  isPartner  Boolean  @default(false) @map("is_partner")
  isFeatured Boolean  @default(false) @map("is_featured")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  geography     Geography?             @relation(fields: [geographyId], references: [id])
  specialties   HospitalSpecialty[]
  doctors       HospitalDoctor[]
  departments   HospitalDepartment[]
  reviews       HospitalReview[]
  insuranceTies HospitalInsuranceTie[]
  enquiries     HospitalEnquiry[]

  @@index([geographyId, isActive])
  @@index([hospitalType, isActive])
  @@index([bedCount])
  @@index([overallRating(sort: Desc)])
  @@index([isFeatured, isActive])
  @@map("hospitals")
}

model HospitalSpecialty {
  id            Int      @id @default(autoincrement())
  hospitalId    Int      @map("hospital_id")
  specialty     String   @db.VarChar(200)
  description   String?
  isCenter      Boolean  @default(false) @map("is_center") // Center of Excellence
  headDoctorId  Int?     @map("head_doctor_id")
  bedCount      Int?     @map("bed_count")
  keyProcedures String[] @default([]) @map("key_procedures")
  successRate   Decimal? @map("success_rate") @db.Decimal(5, 2)
  displayOrder  Int      @default(0) @map("display_order")
  hospital      Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@unique([hospitalId, specialty])
  @@map("hospital_specialties")
}

model HospitalDepartment {
  id               Int      @id @default(autoincrement())
  hospitalId       Int      @map("hospital_id")
  name             String   @db.VarChar(200)
  description      String?
  headDoctorId     Int?     @map("head_doctor_id")
  floorLocation    String?  @map("floor_location") @db.VarChar(50)
  contactExtension String?  @map("contact_extension") @db.VarChar(20)
  operatingHours   Json     @default("{}") @map("operating_hours")
  isEmergency      Boolean  @default(false) @map("is_emergency")
  displayOrder     Int      @default(0) @map("display_order")
  hospital         Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@unique([hospitalId, name])
  @@map("hospital_departments")
}

model HospitalDoctor {
  id              Int             @id @default(autoincrement())
  hospitalId      Int             @map("hospital_id")
  doctorId        Int?            @map("doctor_id") // Link to DoctorProvider if exists
  name            String          @db.VarChar(300)
  slug            String?         @db.VarChar(255)
  designation     String?         @db.VarChar(200)
  specialty       String?         @db.VarChar(200)
  qualifications  String[]        @default([])
  experienceYears Int?            @map("experience_years")
  profileImage    String?         @map("profile_image") @db.VarChar(500)
  bio             String?
  achievements    String[]        @default([])
  notableCases    Json            @default("[]") @map("notable_cases") // Array of {patientType, condition, year}
  isTopDoctor     Boolean         @default(false) @map("is_top_doctor")
  isHod           Boolean         @default(false) @map("is_hod") // Head of Department
  department      String?         @db.VarChar(200)
  consultationFee Decimal?        @map("consultation_fee") @db.Decimal(10, 2)
  availability    Json            @default("{}") // Weekly schedule
  isActive        Boolean         @default(true) @map("is_active")
  hospital        Hospital        @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  doctor          DoctorProvider? @relation(fields: [doctorId], references: [id])

  @@index([hospitalId, isActive])
  @@index([specialty])
  @@index([isTopDoctor])
  @@map("hospital_doctors")
}

model HospitalReview {
  id                Int         @id @default(autoincrement())
  hospitalId        Int         @map("hospital_id")
  reviewerName      String      @map("reviewer_name") @db.VarChar(100)
  reviewerType      PatientType @default(domestic) @map("reviewer_type")
  reviewerCountry   String?     @map("reviewer_country") @db.VarChar(100)
  rating            Int // 1-5
  title             String?     @db.VarChar(200)
  review            String?
  treatmentReceived String?     @map("treatment_received") @db.VarChar(300)
  doctorName        String?     @map("doctor_name") @db.VarChar(200)
  departmentVisited String?     @map("department_visited") @db.VarChar(200)
  visitDate         DateTime?   @map("visit_date") @db.Date

  // Sub-ratings
  doctorRating      Int? @map("doctor_rating")
  staffRating       Int? @map("staff_rating")
  cleanlinessRating Int? @map("cleanliness_rating")
  foodRating        Int? @map("food_rating")
  facilitiesRating  Int? @map("facilities_rating")
  valueRating       Int? @map("value_rating")
  waitTimeRating    Int? @map("wait_time_rating")

  // Detailed feedback
  pros           String[] @default([])
  cons           String[] @default([])
  wouldRecommend Boolean? @map("would_recommend")

  // Moderation
  isVerified   Boolean  @default(false) @map("is_verified")
  isVisible    Boolean  @default(true) @map("is_visible")
  helpfulCount Int      @default(0) @map("helpful_count")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  hospital Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@index([hospitalId, isVisible])
  @@index([reviewerType])
  @@index([rating])
  @@map("hospital_reviews")
}

model HospitalEnquiry {
  id                String      @id @default(uuid()) @db.Uuid
  hospitalId        Int         @map("hospital_id")
  patientName       String      @map("patient_name") @db.VarChar(200)
  patientPhone      String      @map("patient_phone") @db.VarChar(20)
  patientEmail      String?     @map("patient_email") @db.VarChar(200)
  patientCountry    String?     @map("patient_country") @db.VarChar(100)
  patientType       PatientType @default(domestic) @map("patient_type")
  enquiryType       String?     @map("enquiry_type") @db.VarChar(100) // treatment, second opinion, cost estimate
  condition         String?     @db.VarChar(300)
  specialty         String?     @db.VarChar(200)
  preferredDoctor   String?     @map("preferred_doctor") @db.VarChar(200)
  message           String?
  hasInsurance      Boolean     @default(false) @map("has_insurance")
  insuranceProvider String?     @map("insurance_provider") @db.VarChar(200)
  status            LeadStatus  @default(new)
  sessionHash       String?     @map("session_hash") @db.VarChar(64)
  utmSource         String?     @map("utm_source") @db.VarChar(100)
  utmMedium         String?     @map("utm_medium") @db.VarChar(100)
  utmCampaign       String?     @map("utm_campaign") @db.VarChar(100)
  createdAt         DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  hospital          Hospital    @relation(fields: [hospitalId], references: [id])

  @@index([hospitalId, status])
  @@index([patientType])
  @@index([createdAt(sort: Desc)])
  @@map("hospital_enquiries")
}

// ════════════════════════════════════════════════════════════════════════════════
// INSURANCE & TPA SYSTEM
// ════════════════════════════════════════════════════════════════════════════════

model InsuranceProvider {
  id           Int                   @id @default(autoincrement())
  slug         String                @unique @db.VarChar(255)
  name         String                @db.VarChar(300)
  shortName    String?               @map("short_name") @db.VarChar(100)
  providerType InsuranceProviderType @default(private) @map("provider_type")
  description  String?
  logo         String?               @db.VarChar(500)

  // Contact & Location
  headquartersCountry String? @map("headquarters_country") @db.VarChar(100)
  headquartersCity    String? @map("headquarters_city") @db.VarChar(100)
  website             String? @db.VarChar(500)
  customerCarePhone   String? @map("customer_care_phone") @db.VarChar(50)
  claimPhone          String? @map("claim_phone") @db.VarChar(50)
  email               String? @db.VarChar(200)

  // Coverage Areas
  operatingCountries String[] @default([]) @map("operating_countries")
  operatingStates    String[] @default([]) @map("operating_states")

  // Regulatory Info
  licenseNumber        String?  @map("license_number") @db.VarChar(100)
  regulatoryBody       String?  @map("regulatory_body") @db.VarChar(200) // IRDAI, etc.
  establishedYear      Int?     @map("established_year")
  claimSettlementRatio Decimal? @map("claim_settlement_ratio") @db.Decimal(5, 2)

  // Ratings
  rating      Decimal? @db.Decimal(2, 1)
  reviewCount Int      @default(0) @map("review_count")

  // SEO
  metaTitle       String? @map("meta_title") @db.VarChar(160)
  metaDescription String? @map("meta_description") @db.VarChar(300)

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  plans           InsurancePlan[]
  tpaAssociations TpaInsuranceLink[]
  hospitalTies    HospitalInsuranceTie[]
  claims          InsuranceClaim[]

  @@index([providerType, isActive])
  @@index([headquartersCountry])
  @@map("insurance_providers")
}

model InsurancePlan {
  id                 Int               @id @default(autoincrement())
  slug               String            @unique @db.VarChar(255)
  providerId         Int               @map("provider_id")
  name               String            @db.VarChar(300)
  planType           InsurancePlanType @default(individual) @map("plan_type")
  description        String?
  coverageHighlights String[]          @default([]) @map("coverage_highlights")

  // Coverage Details
  sumInsuredMin     Decimal? @map("sum_insured_min") @db.Decimal(15, 2)
  sumInsuredMax     Decimal? @map("sum_insured_max") @db.Decimal(15, 2)
  currency          String   @default("INR") @db.VarChar(3)
  roomRentLimit     String?  @map("room_rent_limit") @db.VarChar(100) // "No cap" or "1% of SI"
  preCoverDays      Int?     @map("pre_cover_days") // Pre-hospitalization
  postCoverDays     Int?     @map("post_cover_days") // Post-hospitalization
  dayCareProcedures Boolean  @default(true) @map("day_care_procedures")
  ambulanceCover    Decimal? @map("ambulance_cover") @db.Decimal(10, 2)
  maternitycover    Boolean  @default(false) @map("maternity_cover")
  ayushCover        Boolean  @default(false) @map("ayush_cover") // Alternative medicine
  organDonorCover   Boolean  @default(false) @map("organ_donor_cover")
  domiciliaryCover  Boolean  @default(false) @map("domiciliary_cover")
  restoreBenefit    Boolean  @default(false) @map("restore_benefit")
  noClaimBonus      String?  @map("no_claim_bonus") @db.VarChar(100) // e.g., "50% increase"

  // Exclusions & Waiting Periods
  preExistingWaitYears Int?     @map("pre_existing_wait_years")
  specificDiseaseWait  Int?     @map("specific_disease_wait_days") // in days
  majorExclusions      String[] @default([]) @map("major_exclusions")

  // Premium Info
  premiumStartsAt  Decimal? @map("premium_starts_at") @db.Decimal(10, 2)
  premiumFrequency String?  @map("premium_frequency") @db.VarChar(50) // monthly, yearly

  // Eligibility
  entryAgeMin   Int? @map("entry_age_min")
  entryAgeMax   Int? @map("entry_age_max")
  renewableUpto Int? @map("renewable_upto") // age

  // Network
  networkHospitalsCount Int? @map("network_hospitals_count")

  isActive   Boolean  @default(true) @map("is_active")
  isFeatured Boolean  @default(false) @map("is_featured")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  provider InsuranceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, isActive])
  @@index([planType])
  @@index([sumInsuredMax])
  @@map("insurance_plans")
}

model Tpa {
  id          Int     @id @default(autoincrement())
  slug        String  @unique @db.VarChar(255)
  name        String  @db.VarChar(300)
  shortName   String? @map("short_name") @db.VarChar(100)
  tpaType     TpaType @default(private) @map("tpa_type")
  description String?
  logo        String? @db.VarChar(500)

  // Contact
  website           String? @db.VarChar(500)
  customerCarePhone String? @map("customer_care_phone") @db.VarChar(50)
  claimHelpline     String? @map("claim_helpline") @db.VarChar(50)
  email             String? @db.VarChar(200)

  // Coverage
  headquartersCity   String?  @map("headquarters_city") @db.VarChar(100)
  operatingCountries String[] @default([]) @map("operating_countries")
  operatingStates    String[] @default([]) @map("operating_states")
  operatingCities    String[] @default([]) @map("operating_cities")

  // Regulatory
  licenseNumber   String? @map("license_number") @db.VarChar(100)
  regulatoryBody  String? @map("regulatory_body") @db.VarChar(200)
  establishedYear Int?    @map("established_year")

  // Stats
  networkHospitalsCount Int? @map("network_hospitals_count")
  livesManaged          Int? @map("lives_managed") // Number of people covered

  // Ratings
  rating      Decimal? @db.Decimal(2, 1)
  reviewCount Int      @default(0) @map("review_count")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  insuranceLinks    TpaInsuranceLink[]
  hospitalLinks     TpaHospitalLink[]
  geographyPresence TpaGeographyPresence[]

  @@index([tpaType, isActive])
  @@map("tpas")
}

model TpaInsuranceLink {
  id            Int               @id @default(autoincrement())
  tpaId         Int               @map("tpa_id")
  insurerId     Int               @map("insurer_id")
  isExclusive   Boolean           @default(false) @map("is_exclusive")
  effectiveFrom DateTime?         @map("effective_from") @db.Date
  effectiveTo   DateTime?         @map("effective_to") @db.Date
  isActive      Boolean           @default(true) @map("is_active")
  tpa           Tpa               @relation(fields: [tpaId], references: [id], onDelete: Cascade)
  insurer       InsuranceProvider @relation(fields: [insurerId], references: [id], onDelete: Cascade)

  @@unique([tpaId, insurerId])
  @@map("tpa_insurance_links")
}

model TpaHospitalLink {
  id              Int      @id @default(autoincrement())
  tpaId           Int      @map("tpa_id")
  hospitalId      Int      @map("hospital_id")
  isCashless      Boolean  @default(true) @map("is_cashless")
  discountPercent Decimal? @map("discount_percent") @db.Decimal(5, 2)
  isActive        Boolean  @default(true) @map("is_active")
  tpa             Tpa      @relation(fields: [tpaId], references: [id], onDelete: Cascade)

  @@unique([tpaId, hospitalId])
  @@index([hospitalId])
  @@map("tpa_hospital_links")
}

model TpaGeographyPresence {
  id            Int       @id @default(autoincrement())
  tpaId         Int       @map("tpa_id")
  geographyId   Int       @map("geography_id")
  officeAddress String?   @map("office_address") @db.VarChar(500)
  phone         String?   @db.VarChar(50)
  isMainOffice  Boolean   @default(false) @map("is_main_office")
  tpa           Tpa       @relation(fields: [tpaId], references: [id], onDelete: Cascade)
  geography     Geography @relation(fields: [geographyId], references: [id])

  @@unique([tpaId, geographyId])
  @@map("tpa_geography_presence")
}

model HospitalInsuranceTie {
  id              Int               @id @default(autoincrement())
  hospitalId      Int               @map("hospital_id")
  insurerId       Int               @map("insurer_id")
  isCashless      Boolean           @default(true) @map("is_cashless")
  isPreferred     Boolean           @default(false) @map("is_preferred")
  discountPercent Decimal?          @map("discount_percent") @db.Decimal(5, 2)
  notes           String?
  isActive        Boolean           @default(true) @map("is_active")
  hospital        Hospital          @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  insurer         InsuranceProvider @relation(fields: [insurerId], references: [id], onDelete: Cascade)

  @@unique([hospitalId, insurerId])
  @@map("hospital_insurance_ties")
}

model InsuranceClaim {
  id             String            @id @default(uuid()) @db.Uuid
  insurerId      Int               @map("insurer_id")
  claimNumber    String?           @map("claim_number") @db.VarChar(100)
  patientName    String            @map("patient_name") @db.VarChar(200)
  patientPhone   String            @map("patient_phone") @db.VarChar(20)
  patientEmail   String?           @map("patient_email") @db.VarChar(200)
  policyNumber   String?           @map("policy_number") @db.VarChar(100)
  claimType      ClaimType         @default(cashless) @map("claim_type")
  hospitalName   String?           @map("hospital_name") @db.VarChar(300)
  admissionDate  DateTime?         @map("admission_date") @db.Date
  dischargeDate  DateTime?         @map("discharge_date") @db.Date
  diagnosis      String?           @db.VarChar(500)
  claimAmount    Decimal?          @map("claim_amount") @db.Decimal(15, 2)
  approvedAmount Decimal?          @map("approved_amount") @db.Decimal(15, 2)
  status         ClaimStatus       @default(submitted)
  notes          String?
  sessionHash    String?           @map("session_hash") @db.VarChar(64)
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  insurer        InsuranceProvider @relation(fields: [insurerId], references: [id])

  @@index([insurerId, status])
  @@index([patientPhone])
  @@map("insurance_claims")
}

