  email                   String?                @db.VarChar(200)
  website                 String?                @db.VarChar(500)
  operatingHours          Json                   @default("{}") @map("operating_hours")
  accreditations          String[]               @default([]) // NABL, CAP, JCI, etc.
  servicesOffered         String[]               @default([]) @map("services_offered")
  homeCollectionAvailable Boolean                @default(false) @map("home_collection_available")
  homeCollectionFee       Decimal?               @map("home_collection_fee") @db.Decimal(10, 2)
  homeCollectionAreas     String[]               @default([]) @map("home_collection_areas") // area slugs
  onlineReportsAvailable  Boolean                @default(true) @map("online_reports_available")
  reportDeliveryMethods   String[]               @default([]) @map("report_delivery_methods")
  partnerDiscount         Decimal?               @map("partner_discount") @db.Decimal(5, 2) // % discount via AIHealz
  partnerCommission       Decimal?               @map("partner_commission") @db.Decimal(5, 2) // our commission %
  isPartner               Boolean                @default(false) @map("is_partner") // official partner
  isVerified              Boolean                @default(false) @map("is_verified")
  subscriptionTier        SubscriptionTier       @default(free) @map("subscription_tier")
  rating                  Decimal?               @db.Decimal(2, 1)
  reviewCount             Int                    @default(0) @map("review_count")
  totalBookings           Int                    @default(0) @map("total_bookings")
  latitude                Decimal?               @db.Decimal(10, 7)
  longitude               Decimal?               @db.Decimal(10, 7)
  googlePlaceId           String?                @unique @map("google_place_id") @db.VarChar(255)
  images                  String[]               @default([])
  schemaMarkup            Json?                  @map("schema_markup")
  isActive                Boolean                @default(true) @map("is_active")
  createdAt               DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  geography               Geography?             @relation(fields: [geographyId], references: [id])
  testPrices              DiagnosticTestPrice[]
  packages                DiagnosticPackage[]
  bookings                DiagnosticBooking[]
  reviews                 DiagnosticReview[]

  @@index([geographyId, isActive])
  @@index([providerType, isActive])
  @@index([isPartner, isActive])
  @@index([rating(sort: Desc)])
  @@map("diagnostic_providers")
}

model DiagnosticTestPrice {
  id              Int                @id @default(autoincrement())
  testId          Int                @map("test_id")
  providerId      Int                @map("provider_id")
  price           Decimal            @db.Decimal(10, 2)
  currency        String             @default("INR") @db.VarChar(3)
  mrpPrice        Decimal?           @map("mrp_price") @db.Decimal(10, 2) // original price before discount
  discountPercent Decimal?           @map("discount_percent") @db.Decimal(5, 2)
  reportTimeHours Int?               @map("report_time_hours") // provider-specific turnaround
  homeCollection  Boolean            @default(false) @map("home_collection")
  isActive        Boolean            @default(true) @map("is_active")
  lastUpdated     DateTime           @default(now()) @map("last_updated") @db.Timestamptz(6)
  test            DiagnosticTest     @relation(fields: [testId], references: [id], onDelete: Cascade)
  provider        DiagnosticProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([testId, providerId])
  @@index([providerId, isActive])
  @@index([price])
  @@map("diagnostic_test_prices")
}

model DiagnosticPackage {
  id              Int                     @id @default(autoincrement())
  slug            String                  @unique @db.VarChar(255)
  name            String                  @db.VarChar(300)
  providerId      Int                     @map("provider_id")
  description     String?
  packageType     DiagnosticPackageType   @default(health_checkup) @map("package_type")
  targetAudience  String?                 @map("target_audience") @db.VarChar(100) // men, women, seniors, etc.
  ageGroupMin     Int?                    @map("age_group_min")
  ageGroupMax     Int?                    @map("age_group_max")
  price           Decimal                 @db.Decimal(10, 2)
  currency        String                  @default("INR") @db.VarChar(3)
  mrpPrice        Decimal?                @map("mrp_price") @db.Decimal(10, 2)
  discountPercent Decimal?                @map("discount_percent") @db.Decimal(5, 2)
  testCount       Int                     @default(0) @map("test_count")
  reportTimeHours Int?                    @map("report_time_hours")
  fastingRequired Boolean                 @default(false) @map("fasting_required")
  homeCollection  Boolean                 @default(false) @map("home_collection")
  isFeatured      Boolean                 @default(false) @map("is_featured")
  displayOrder    Int                     @default(0) @map("display_order")
  isActive        Boolean                 @default(true) @map("is_active")
  createdAt       DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime                @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  provider        DiagnosticProvider      @relation(fields: [providerId], references: [id], onDelete: Cascade)
  tests           DiagnosticPackageTest[]
  bookings        DiagnosticBooking[]

  @@index([providerId, isActive])
  @@index([packageType, isActive])
  @@index([isFeatured, isActive])
  @@map("diagnostic_packages")
}

model DiagnosticPackageTest {
  id           Int               @id @default(autoincrement())
  packageId    Int               @map("package_id")
  testId       Int               @map("test_id")
  displayOrder Int               @default(0) @map("display_order")
  package      DiagnosticPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  test         DiagnosticTest    @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@unique([packageId, testId])
  @@map("diagnostic_package_tests")
}

model DiagnosticBooking {
  id                String                  @id @default(uuid()) @db.Uuid
  providerId        Int                     @map("provider_id")
  testId            Int?                    @map("test_id") // null if booking a package
  packageId         Int?                    @map("package_id")
  sessionHash       String?                 @map("session_hash") @db.VarChar(64)
  patientName       String                  @map("patient_name") @db.VarChar(200)
  patientPhone      String                  @map("patient_phone") @db.VarChar(20)
  patientEmail      String?                 @map("patient_email") @db.VarChar(200)
  patientAge        Int?                    @map("patient_age")
  patientGender     String?                 @map("patient_gender") @db.VarChar(20)
  collectionType    CollectionType          @default(walk_in) @map("collection_type")
  collectionAddress String?                 @map("collection_address") @db.VarChar(500)
  collectionSlot    DateTime?               @map("collection_slot") @db.Timestamptz(6)
  geographyId       Int?                    @map("geography_id")
  price             Decimal                 @db.Decimal(10, 2)
  currency          String                  @default("INR") @db.VarChar(3)
  discountApplied   Decimal?                @map("discount_applied") @db.Decimal(10, 2)
  finalPrice        Decimal                 @map("final_price") @db.Decimal(10, 2)
  status            DiagnosticBookingStatus @default(pending)
  providerConfirmed Boolean                 @default(false) @map("provider_confirmed")
  paymentStatus     PaymentStatus           @default(pending) @map("payment_status")
  paymentId         String?                 @map("payment_id") @db.VarChar(100)
  reportUrl         String?                 @map("report_url") @db.VarChar(500)
  reportUploadedAt  DateTime?               @map("report_uploaded_at") @db.Timestamptz(6)
  utmSource         String?                 @map("utm_source") @db.VarChar(100)
  utmMedium         String?                 @map("utm_medium") @db.VarChar(100)
  utmCampaign       String?                 @map("utm_campaign") @db.VarChar(100)
  notes             String?
  createdAt         DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime                @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  provider          DiagnosticProvider      @relation(fields: [providerId], references: [id])
  test              DiagnosticTest?         @relation(fields: [testId], references: [id])
  package           DiagnosticPackage?      @relation(fields: [packageId], references: [id])

  @@index([providerId, status])
  @@index([status, createdAt])
  @@index([sessionHash])
  @@index([patientPhone])
  @@map("diagnostic_bookings")
}

model DiagnosticReview {
  id             Int                @id @default(autoincrement())
  providerId     Int                @map("provider_id")
  bookingId      String?            @map("booking_id") @db.Uuid
  reviewerName   String             @map("reviewer_name") @db.VarChar(100)
  rating         Int // 1-5
  title          String?            @db.VarChar(200)
  review         String?
  pros           String[]           @default([])
  cons           String[]           @default([])
  serviceRating  Int?               @map("service_rating") // 1-5
  reportQuality  Int?               @map("report_quality") // 1-5
  punctuality    Int? // 1-5
  homeCollection Int?               @map("home_collection") // 1-5
  isVerified     Boolean            @default(false) @map("is_verified")
  isVisible      Boolean            @default(true) @map("is_visible")
  helpfulCount   Int                @default(0) @map("helpful_count")
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  provider       DiagnosticProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, isVisible])
  @@index([rating])
  @@map("diagnostic_reviews")
}

// New enums for diagnostics
enum DiagnosticTestType {
  lab_test // blood, urine tests
  imaging // X-ray, CT, MRI, Ultrasound
  pathology // biopsy, histopathology
  genetic // DNA, genetic screening
  cardiac // ECG, Echo, stress test
  pulmonary // PFT, spirometry
  endoscopy // gastroscopy, colonoscopy
  other
}

enum DiagnosticProviderType {
  lab // pathology lab
  imaging_center // radiology center
  hospital // hospital diagnostic dept
  clinic // clinic with diagnostics
  home_collection // mobile collection service
  full_service // all diagnostic services
}

enum DiagnosticPackageType {
  health_checkup // full body checkup
  disease_specific // diabetes panel, cardiac panel
  organ_specific // liver, kidney, thyroid
  age_specific // pediatric, geriatric
  gender_specific // women's health, men's health
  lifestyle // fitness, wellness
