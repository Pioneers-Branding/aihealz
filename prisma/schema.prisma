// === SEO Content Generation Framework ===

enum ConditionPageStatus {
  draft
  review
  published
  archived
}

model ConditionPageContent {
  id           Int    @id @default(autoincrement())
  conditionId  Int    @map("condition_id")
  languageCode String @default("en") @map("language_code") @db.VarChar(5)

  // Hero Section
  h1Title      String? @map("h1_title") @db.VarChar(200)
  heroOverview String? @map("hero_overview")
  keyStats     Json?   @map("key_stats") // {prevalence, demographics, avgAge, globalCases}

  // Section 1: Overview
  definition          String?
  typesClassification Json?   @map("types_classification") // [{type, description}]

  // Section 2: Symptoms
  primarySymptoms   Json? @map("primary_symptoms") // [symptom strings]
  earlyWarningSigns Json? @map("early_warning_signs")
  emergencySigns    Json? @map("emergency_signs")

  // Section 3: Causes & Risk Factors
  causes               Json? // [{cause, description}]
  riskFactors          Json? @map("risk_factors") // [{factor, category, description}]
  affectedDemographics Json? @map("affected_demographics")

  // Section 4: Diagnosis
  diagnosisOverview String? @map("diagnosis_overview")
  diagnosticTests   Json?   @map("diagnostic_tests") // [{test, purpose, whatToExpect}]

  // Section 5: Treatments
  treatmentOverview     String? @map("treatment_overview")
  medicalTreatments     Json?   @map("medical_treatments") // [{name, description, effectiveness}]
  surgicalOptions       Json?   @map("surgical_options")
  alternativeTreatments Json?   @map("alternative_treatments")
  linkedTreatmentSlugs  Json?   @map("linked_treatment_slugs") // [treatment slugs for cards]

  // Section 6: Doctors
  specialistType       String? @map("specialist_type") @db.VarChar(100)
  whySeeSpecialist     String? @map("why_see_specialist")
  doctorSelectionGuide String? @map("doctor_selection_guide")

  // Section 7: Hospitals
  hospitalCriteria Json? @map("hospital_criteria")
  keyFacilities    Json? @map("key_facilities")

  // Section 8: Costs
  costBreakdown       Json?   @map("cost_breakdown") // [{treatment, minCost, maxCost, currency}]
  insuranceGuide      String? @map("insurance_guide")
  financialAssistance String? @map("financial_assistance")

  // Section 9: Prevention & Lifestyle
  preventionStrategies   Json?   @map("prevention_strategies")
  lifestyleModifications Json?   @map("lifestyle_modifications")
  dietRecommendations    Json?   @map("diet_recommendations")
  exerciseGuidelines     String? @map("exercise_guidelines")

  // Section 10: Living With
  dailyManagement  Json?   @map("daily_management")
  prognosis        String?
  recoveryTimeline String? @map("recovery_timeline")
  complications    Json?
  supportResources Json?   @map("support_resources")

  // Section 11: Related Conditions
  confusedWithConditions Json? @map("confused_with_conditions") // [{slug, name, keyDifference}]
  coOccurringConditions  Json? @map("co_occurring_conditions")
  relatedConditions      Json? @map("related_conditions")

  // Section 12: FAQs (20+)
  faqs Json? // [{question, answer, schemaEligible}]

  // Simple Names & Regional Tags (for searchability)
  simpleName      String? @map("simple_name") @db.VarChar(300) // Non-medical term in local language
  regionalNames   Json?   @map("regional_names") // [{name, region, language}] - regional variations
  searchTags      Json?   @map("search_tags") // All searchable terms combined for search bar
  symptomKeywords Json?   @map("symptom_keywords") // Common symptoms as searchable keywords

  // SEO Meta
  metaTitle       String? @map("meta_title") @db.VarChar(60)
  metaDescription String? @map("meta_description") @db.VarChar(160)
  canonicalUrl    String? @map("canonical_url") @db.VarChar(500)
  keywords        Json? // [keyword strings]

  // EEAT Signals
  reviewedByDoctorId Int?      @map("reviewed_by_doctor_id")
  lastReviewed       DateTime? @map("last_reviewed") @db.Date
  sources            Json? // [{title, url, accessedDate}]

  // Pre-generated Schema Markup
  schemaMedicalCondition Json? @map("schema_medical_condition")
  schemaFaqPage          Json? @map("schema_faq_page")
  schemaBreadcrumb       Json? @map("schema_breadcrumb")
  schemaHowTo            Json? @map("schema_how_to")

  // Quality & Status
  status            ConditionPageStatus @default(draft)
  qualityScore      Decimal?            @map("quality_score") @db.Decimal(3, 2)
  wordCount         Int?                @map("word_count")
  generationVersion String?             @map("generation_version") @db.VarChar(20)
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  condition MedicalCondition @relation(fields: [conditionId], references: [id], onDelete: Cascade)
  reviewer  DoctorProvider?  @relation("PageContentReviewer", fields: [reviewedByDoctorId], references: [id])

  @@unique([conditionId, languageCode])
  @@index([status])
  @@index([specialistType])
  @@index([qualityScore(sort: Desc)])
  @@map("condition_page_content")
}

