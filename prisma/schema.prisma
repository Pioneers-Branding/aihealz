  id                      Int                    @id @default(autoincrement())
  slug                    String                 @unique @db.VarChar(255)
  name                    String                 @db.VarChar(300)
  providerType            DiagnosticProviderType @default(lab) @map("provider_type")
  description             String?
  logo                    String?                @db.VarChar(500)
