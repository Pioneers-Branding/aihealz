{
  "name": "aihealz",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "generate:conditions": "npx tsx scripts/generate-conditions/batch-runner.ts",
    "generate:conditions:cardiology": "npx tsx scripts/generate-conditions/batch-runner.ts --specialty=Cardiology",
    "generate:conditions:all": "npx tsx scripts/generate-conditions/batch-runner.ts --all --concurrency=5",
    "generate:conditions:resume": "npx tsx scripts/generate-conditions/batch-runner.ts --resume",
    "validate:conditions": "npx tsx scripts/generate-conditions/batch-runner.ts --validate",
    "generate:conditions:stats": "npx tsx scripts/generate-conditions/batch-runner.ts --stats",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "seed:doctors": "npx tsx scripts/seed-doctors.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@stripe/stripe-js": "^8.8.0",
