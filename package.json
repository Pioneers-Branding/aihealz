    "autoprefixer": "^10.4.24",
    "bcryptjs": "^3.0.3",
    "dompurify": "^3.3.1",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.34.3",
    "ioredis": "^5.9.3",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "pg": "^8.18.0",
    "postcss": "^8.5.6",
    "prisma": "^7.4.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "stripe": "^20.3.1",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
