        { "key": "tbsa", "label": "Total Body Surface Area burned (%)", "type": "number" }
      ],
      "formula": "LR = 4 mL × weight (kg) × TBSA burned (%)",
      "interpretation": [
        { "range": [0, 100], "risk": "24hr fluid requirement", "action": "Give 50% in first 8 hours, 50% in next 16 hours. Titrate to UOP 0.5-1 mL/kg/hr" }
      ]
    },
    {
