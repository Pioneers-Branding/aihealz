      ],
      "interpretation": [
        { "range": [90, 200], "risk": "G1: Normal or High", "action": "Monitor if other signs of CKD" },
        { "range": [60, 89], "risk": "G2: Mild decrease", "action": "Monitor annually" },
        { "range": [45, 59], "risk": "G3a: Mild-moderate", "action": "Nephrology referral; adjust medications" },
        { "range": [30, 44], "risk": "G3b: Moderate-severe", "action": "Nephrology co-management" },
        { "range": [15, 29], "risk": "G4: Severe decrease", "action": "Prepare for RRT; nephrology" },
        { "range": [0, 14], "risk": "G5: Kidney failure", "action": "Dialysis or transplant evaluation" }
      ]
    },
    {
      "id": "corrected_calcium",
      "name": "Corrected Calcium",
      "category": "nephrology",
      "description": "Adjusts calcium for albumin level",
      "reference": "Payne RB, et al. Br Med J 1973",
      "fields": [
        { "key": "calcium", "label": "Serum Calcium (mg/dL)", "type": "number" },
        { "key": "albumin", "label": "Serum Albumin (g/dL)", "type": "number" }
      ],
      "formula": "Corrected Ca = Measured Ca + 0.8 × (4.0 - Albumin)",
      "interpretation": [
        { "range": [8.5, 10.5], "risk": "Normal", "action": "No action needed" },
        { "range": [10.6, 12], "risk": "Mild hypercalcemia", "action": "Investigate etiology" },
        { "range": [12.1, 14], "risk": "Moderate hypercalcemia", "action": "IV fluids; bisphosphonates" },
        { "range": [14.1, 20], "risk": "Severe hypercalcemia", "action": "Emergency treatment; ICU" }
      ]
    },
    {
      "id": "anion_gap",
      "name": "Anion Gap",
      "category": "critical_care",
      "description": "Evaluates metabolic acidosis etiology",
      "reference": "Emmett M, Narins RG. Medicine 1977",
      "fields": [
        { "key": "sodium", "label": "Sodium (mEq/L)", "type": "number" },
        { "key": "chloride", "label": "Chloride (mEq/L)", "type": "number" },
        { "key": "bicarb", "label": "Bicarbonate (mEq/L)", "type": "number" },
        { "key": "albumin", "label": "Albumin (g/dL) - for correction", "type": "number" }
      ],
      "formula": "AG = Na - (Cl + HCO3); Corrected AG = AG + 2.5 × (4 - Albumin)",
      "interpretation": [
        { "range": [8, 12], "risk": "Normal", "action": "If acidosis, consider non-AG causes (RTA, diarrhea)" },
        { "range": [13, 20], "risk": "Elevated AG", "action": "MUDPILES: Methanol, Uremia, DKA, Propylene glycol, INH/Iron, Lactic acid, Ethylene glycol, Salicylates" },
        { "range": [21, 50], "risk": "High AG", "action": "Severe metabolic acidosis; urgent workup" }
      ]
    }
  ]
