  "calculators": [
    {
      "id": "crcl",
      "name": "Creatinine Clearance (Cockcroft-Gault)",
      "formula": "CrCl = [(140-age) × weight × (0.85 if female)] / (72 × SCr)",
      "inputs": ["age", "weight", "scr", "sex"],
      "unit": "mL/min"
    },
    {
      "id": "ibw",
      "name": "Ideal Body Weight",
      "formula": "IBW = 50 kg + 2.3 kg per inch over 5 feet (males) or 45.5 kg + 2.3 kg per inch over 5 feet (females)",
      "inputs": ["height", "sex"],
      "unit": "kg"
    },
    {
      "id": "abw",
      "name": "Adjusted Body Weight",
      "formula": "ABW = IBW + 0.4 × (Actual - IBW)",
      "inputs": ["weight", "ibw"],
      "unit": "kg"
    },
    {
      "id": "infusion_rate",
      "name": "IV Infusion Rate",
      "formula": "Rate (mL/hr) = (Dose × Weight × 60) / Concentration",
      "inputs": ["dose_mcg_kg_min", "weight", "concentration_mg_ml"],
      "unit": "mL/hr"
    }
  ]
